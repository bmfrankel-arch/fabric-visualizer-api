# Frontend env vars for `vite build`.
# All are optional. When set, they enable "brand mode":
# the UI locks to one furniture retailer and uses an API key instead of
# Basic Auth against the backend.

# Required when brand mode is on.
# Backend URL (the shared Railway API). Leave blank if the frontend is
# served by the same backend (the internal Railway deploy does this).
VITE_BACKEND_URL=https://fabric-visualizer-api-production.up.railway.app

# Brand key. Must match a retailer key on the backend (e.g. bernhardt,
# crlaine, hickorychair, rowe). Also must be the brand name registered
# in FV_BRAND_API_KEYS on the backend.
VITE_BRAND_KEY=

# Display name shown in the header. Defaults to the brand key if blank.
VITE_BRAND_NAME=

# Optional logo to show in the sidebar.
VITE_BRAND_LOGO_URL=

# Optional CSS accent color (any valid CSS color).
VITE_BRAND_ACCENT=

# API key issued by the backend. Required when VITE_BRAND_KEY is set.
# This is sent as the X-API-Key header on every API request.
VITE_API_KEY=
