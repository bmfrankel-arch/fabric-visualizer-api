# Copy this to .env and fill in your values
# On Railway: set these as environment variables in the dashboard

# Required for AI visualization mode
FV_OPENAI_API_KEY=sk-...

# Optional: Replicate API for alternative AI mode
# FV_REPLICATE_API_TOKEN=r8_...

# Upload directory (Railway uses /tmp or a mounted volume)
# FV_UPLOAD_DIR=/tmp/fv_uploads
